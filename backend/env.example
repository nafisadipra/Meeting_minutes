# Paths
MODELS_ROOT=./models
DATA_ROOT=./data
VOICE_PROFILES_DIR=voice_profiles
MINUTES_FILE=minutes.txt

# Whisper — CTranslate2 does not support MPS/Metal; CPU+int8 uses ARM NEON on Apple Silicon.
WHISPER_MODEL_PATH=./models/whisper/base.en
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# SpeechBrain — auto-selects MPS on Apple Silicon, CUDA on NVIDIA, CPU otherwise.
SPEECHBRAIN_MODEL_PATH=./models/speechbrain/spkrec-ecapa-voxceleb

# Ollama
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=llama3.2:3b

# Flask (web mode only)
FLASK_PORT=5000
FLASK_DEBUG=False
